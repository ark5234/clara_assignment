# ─────────────────────────────────────────────────────────────────────────────
# Clara AI — Environment Variables
# Copy this file to .env and fill in the values for your chosen LLM provider.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Select your zero-cost provider. Recommended: gemini (free, no credit card).
# Options: gemini | groq | ollama | openai
LLM_PROVIDER=gemini

# ── Google Gemini (RECOMMENDED — zero cost) ──────────────────────────────────
# Free tier: 15 requests/min, 1 million tokens/day
# Get API key (free, no credit card): https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Groq (alternative zero cost) ─────────────────────────────────────────────
# Free tier: 6,000 tokens/min, 500k tokens/day (very fast)
# Get API key (free): https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama (local, fully offline) ────────────────────────────────────────────
# Install Ollama: https://ollama.ai  then run: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── OpenAI (paid — only if you already have credits) ─────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ── Shared LLM settings ───────────────────────────────────────────────────────
OPENAI_TEMPERATURE=0.0

# ── Storage ───────────────────────────────────────────────────────────────────
# Root directory for all output artifacts
CLARA_OUTPUT_DIR=outputs/accounts

# ── Task Tracker ─────────────────────────────────────────────────────────────
# Options: local | github
TASK_TRACKER_BACKEND=local
TASK_TRACKER_FILE=outputs/task_tracker.json
# For GitHub Issues backend (optional):
# GITHUB_TOKEN=your_github_token
# GITHUB_REPO=your-org/your-repo

# ── Logging ───────────────────────────────────────────────────────────────────
CLARA_LOG_LEVEL=INFO
